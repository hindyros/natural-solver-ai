# ── Backend provider ──────────────────────────────────────────────────────────
# Options: stackai (default) | optimate
BACKEND_PROVIDER=stackai

# ── Stack AI credentials (required when BACKEND_PROVIDER=stackai) ─────────────
STACK_AI_PUBLIC_KEY=your_stack_ai_public_key
STACK_AI_ORG_ID=your_org_id
STACK_AI_FLOW_ID=your_flow_id

# ── OptiMATE v1-light (required when BACKEND_PROVIDER=optimate) ───────────────
# Absolute path to your local OptiMATE-v1-light repo
OPTIMATE_DIR=/absolute/path/to/OptiMATE-v1-light
# Python executable — use the venv python for OptiMATE
OPTIMATE_PYTHON=/absolute/path/to/OptiMATE-v1-light/venv/bin/python
# LLM provider for OptiMATE: anthropic | openai | groq (default: openai)
OPTIMATE_LLM_PROVIDER=openai
# API key for the chosen provider
OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# GROQ_API_KEY=gsk_...

# ── Redis (optional — falls back to in-memory if not set) ─────────────────────
UPSTASH_REDIS_REST_URL=your_upstash_url
UPSTASH_REDIS_REST_TOKEN=your_upstash_token

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3001
