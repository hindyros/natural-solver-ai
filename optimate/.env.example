# ── LLM Provider ─────────────────────────────────────────────────────────────
# Options: anthropic | openai | groq  (default: anthropic)
LLM_PROVIDER=anthropic

# Set whichever key matches your chosen provider
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
GROQ_API_KEY=gsk_...

# Optional: override default models for the selected provider
# OPTIMATE_HEAVY_MODEL=claude-sonnet-4-6
# OPTIMATE_LIGHT_MODEL=claude-haiku-4-5-20251001

# Optional: custom OpenAI-compatible base URL (e.g. LM Studio, Azure, Together AI)
# OPENAI_BASE_URL=http://localhost:1234/v1
